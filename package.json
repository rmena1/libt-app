{
  "name": "libt-app",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rmena1/libt-app.git"
  },
  "bugs": {
    "url": "https://github.com/rmena1/libt-app/issues"
  },
  "homepage": "https://github.com/rmena1/libt-app#readme",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "npm run db:verify && next start",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:setup": "node scripts/db-setup.mjs",
    "db:seed": "node scripts/db-seed.mjs",
    "db:reset": "node scripts/db-reset.mjs",
    "db:bootstrap": "node scripts/db-bootstrap.mjs",
    "db:verify": "node scripts/db-verify.mjs",
    "db:studio": "drizzle-kit studio",
    "test": "npm run test:unit",
    "test:unit": "node --test --experimental-strip-types \"src/**/*.test.ts\"",
    "test:e2e": "playwright test",
    "zero:deploy-permissions": "zero-deploy-permissions --schema-path ./schema.mts",
    "zero:start": "npm run db:verify && npx zero-cache",
    "zero:dev": "ZERO_UPSTREAM_DB=postgresql://postgres:postgres@localhost:55432/libt_app ZERO_QUERY_URL=http://localhost:3000/api/zero/query ZERO_MUTATE_URL=http://localhost:3000/api/zero/mutate ZERO_QUERY_FORWARD_COOKIES=true ZERO_MUTATE_FORWARD_COOKIES=true npx zero-cache-dev"
  },
  "dependencies": {
    "@rocicorp/undo": "0.2.1",
    "@rocicorp/zero": "0.25.12",
    "@types/pg": "8.16.0",
    "bcryptjs": "3.0.3",
    "better-sqlite3": "12.6.2",
    "clsx": "2.1.1",
    "drizzle-orm": "0.45.1",
    "ffmpeg-static": "5.3.0",
    "nanoid": "5.1.6",
    "next": "16.1.6",
    "pg": "8.17.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "10.1.0",
    "tailwind-merge": "3.4.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "1.58.0",
    "@tailwindcss/postcss": "4.1.18",
    "@types/bcryptjs": "2.4.6",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "20.19.30",
    "@types/react": "19.2.10",
    "@types/react-dom": "19.2.3",
    "drizzle-kit": "0.31.8",
    "eslint": "9.39.2",
    "eslint-config-next": "16.1.4",
    "playwright": "1.58.0",
    "tailwindcss": "4.1.18",
    "typescript": "5.9.3"
  }
}
